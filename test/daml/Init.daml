-- On-ledger seed for the demo. Run against LocalNet or a Devnet participant:
--   daml script --dar test/.daml/dist/tirai-test-0.1.0.dar \
--     --script-name Init:initialize --ledger-host <host> --ledger-port <port>
-- initialize   : parties + holdings + an open RFQ with two sealed quotes
-- holdingsOnly : parties + holdings only (RFQ/quotes driven live in the UI/demo)
module Init where

import DA.Date (Month(Jan), date)
import DA.Foldable (forA_)
import DA.Time (time)
import Daml.Script
import Tirai

data Parties = Parties
  with
    buyer : Party
    dealerA : Party
    dealerB : Party
    regulator : Party
    cashIssuer : Party
    bondIssuer : Party
  deriving (Eq, Show)

-- Allocate the demo parties and fund them: buyer holds cash, each dealer a bond.
setup : Script (Parties, ContractId Holding, ContractId Holding)
setup = do
  buyer <- allocateParty "Buyer"
  dealerA <- allocateParty "DealerA"
  dealerB <- allocateParty "DealerB"
  regulator <- allocateParty "Regulator"
  cashIssuer <- allocateParty "CashIssuer"
  bondIssuer <- allocateParty "BondIssuer"
  let parties = Parties with buyer; dealerA; dealerB; regulator; cashIssuer; bondIssuer

  _ <- submit cashIssuer do
    createCmd Holding with
      issuer = cashIssuer; owner = buyer; instrument = "USDC"; amount = 5000000.0
  bondA <- submit bondIssuer do
    createCmd Holding with
      issuer = bondIssuer; owner = dealerA; instrument = "TBOND30"; amount = 1000.0
  bondB <- submit bondIssuer do
    createCmd Holding with
      issuer = bondIssuer; owner = dealerB; instrument = "TBOND30"; amount = 1000.0

  forA_ [ ("buyer", buyer), ("dealerA", dealerA), ("dealerB", dealerB)
        , ("regulator", regulator) ] \(label, p) -> debug (label <> " = " <> show p)
  pure (parties, bondA, bondB)

-- ---- helpers for the rich demo seed ----
farFut : Time
farFut = time (date 2030 Jan 1) 0 0 0

cashFor : Parties -> Decimal -> Script (ContractId Holding)
cashFor p amt = submit p.cashIssuer do
  createCmd Holding with issuer = p.cashIssuer; owner = p.buyer; instrument = "USDC"; amount = amt

bondFor : Parties -> Party -> Text -> Decimal -> Script (ContractId Holding)
bondFor p owner inst qty = submit p.bondIssuer do
  createCmd Holding with issuer = p.bondIssuer; owner; instrument = inst; amount = qty

rfqFor : Parties -> [Party] -> Text -> Decimal -> Script (ContractId RFQ)
rfqFor p dealers inst qty = submit p.buyer do
  createCmd RFQ with
    buyer = p.buyer; regulator = p.regulator; invitedDealers = dealers
    instrument = inst; quantity = qty; payInstrument = "USDC"
    assetIssuer = Some p.bondIssuer; payIssuer = Some p.cashIssuer; deadline = Some farFut

qOn : ContractId RFQ -> Party -> Decimal -> ContractId Holding -> Script (ContractId Quote)
qOn rfq dealer price asset = submit dealer do
  exerciseCmd rfq SubmitQuote with dealer; price; assetCid = asset

-- A RICH pre-seeded desk: several settled trades across settlement modes and
-- instruments (so the regulator's audit is realistic on open), plus an open RFQ
-- and an open basket to drive live. Run with: npm run demo:cases
richSeed : Script Parties
richSeed = do
  (p, _, _) <- setup

  -- 1 · Vickrey (2 dealers): GILT10, A 190k / B 195k → A paid the 2nd price 195k.
  do c <- cashFor p 200000.0; ga <- bondFor p p.dealerA "GILT10" 100.0; gb <- bondFor p p.dealerB "GILT10" 100.0
     rfq <- rfqFor p [p.dealerA, p.dealerB] "GILT10" 100.0
     qa <- qOn rfq p.dealerA 190000.0 ga; qb <- qOn rfq p.dealerB 195000.0 gb
     submit p.buyer do exerciseCmd rfq Award with quoteCids = [qa, qb]; cashCid = c
  -- 2 · Direct OTC (settle at ask): German Bund 10Y, 500 @ 495,000.
  do c <- cashFor p 495000.0; ba <- bondFor p p.dealerA "BUND10" 500.0
     rfq <- rfqFor p [p.dealerA, p.dealerB] "BUND10" 500.0
     qa <- qOn rfq p.dealerA 495000.0 ba
     submit p.buyer do exerciseCmd qa SettleQuote with cashCid = c; clearingPrice = 495000.0
     submit p.buyer do exerciseCmd rfq CancelRFQ -- tidy the settled RFQ shell
  -- 3 · Partial fill: Apple 2030 corp, ask 520k on 500, buyer fills 300 → 312,000.
  do c <- cashFor p 520000.0; ba <- bondFor p p.dealerA "AAPL30" 500.0
     rfq <- rfqFor p [p.dealerA, p.dealerB] "AAPL30" 500.0
     qa <- qOn rfq p.dealerA 520000.0 ba
     submit p.buyer do exerciseCmd qa AcceptPartial with cashCid = c; fillQuantity = 300.0
     submit p.buyer do exerciseCmd rfq CancelRFQ -- tidy the settled RFQ shell
  -- 4 · Three-dealer Vickrey: US Treasury 5Y, A 1.470M / B 1.485M / C 1.500M → 1.485M.
  do dealerC <- allocateParty "DealerC"
     c <- cashFor p 1500000.0
     ba <- bondFor p p.dealerA "UST5Y" 1500.0; bb <- bondFor p p.dealerB "UST5Y" 1500.0; bc <- bondFor p dealerC "UST5Y" 1500.0
     rfq <- rfqFor p [p.dealerA, p.dealerB, dealerC] "UST5Y" 1500.0
     qa <- qOn rfq p.dealerA 1470000.0 ba; qb <- qOn rfq p.dealerB 1485000.0 bb; qc <- qOn rfq dealerC 1500000.0 bc
     submit p.buyer do exerciseCmd rfq Award with quoteCids = [qa, qb, qc]; cashCid = c
  -- 5 · Basket settled (atomic multi-leg): [US Treasury 10Y ×1000 + JPMorgan 2028 ×200] @ 2.30M.
  do c <- cashFor p 2300000.0; t <- bondFor p p.dealerA "UST10Y" 1000.0; j <- bondFor p p.dealerA "JPM28" 200.0
     let legs = [Leg "UST10Y" 1000.0 (Some p.bondIssuer), Leg "JPM28" 200.0 (Some p.bondIssuer)]
     brfq <- submit p.buyer do
       createCmd BasketRFQ with buyer = p.buyer; regulator = p.regulator; invitedDealers = [p.dealerA, p.dealerB]
                                legs; payInstrument = "USDC"; payIssuer = Some p.cashIssuer; deadline = Some farFut
     bq <- submit p.dealerA do exerciseCmd brfq SubmitBasketQuote with dealer = p.dealerA; price = 2300000.0; assetCids = [t, j]
     submit p.buyer do exerciseCmd bq SettleBasket with cashCid = c
     submit p.buyer do archiveCmd brfq -- tidy the settled BasketRFQ shell

  -- OPEN RFQ (the money shot, un-settled): TBOND30 with two sealed quotes.
  do ba <- bondFor p p.dealerA "TBOND30" 1000.0; bb <- bondFor p p.dealerB "TBOND30" 1000.0
     rfq <- rfqFor p [p.dealerA, p.dealerB] "TBOND30" 1000.0
     _ <- qOn rfq p.dealerA 4210000.0 ba; _ <- qOn rfq p.dealerB 4250000.0 bb
     pure ()
  -- OPEN basket (un-settled): [TBOND30 ×1000 + GILT10 ×100] with a sealed quote.
  do ta <- bondFor p p.dealerA "TBOND30" 1000.0; ga <- bondFor p p.dealerA "GILT10" 100.0
     let legs = [Leg "TBOND30" 1000.0 (Some p.bondIssuer), Leg "GILT10" 100.0 (Some p.bondIssuer)]
     brfq <- submit p.buyer do
       createCmd BasketRFQ with buyer = p.buyer; regulator = p.regulator; invitedDealers = [p.dealerA, p.dealerB]
                                legs; payInstrument = "USDC"; payIssuer = Some p.cashIssuer; deadline = Some farFut
     _ <- submit p.dealerA do exerciseCmd brfq SubmitBasketQuote with dealer = p.dealerA; price = 4400000.0; assetCids = [ta, ga]
     pure ()

  -- A working cash balance so the buyer can still drive live settlements.
  _ <- cashFor p 5000000.0
  forA_ [ ("buyer", p.buyer), ("dealerA", p.dealerA), ("dealerB", p.dealerB), ("regulator", p.regulator) ]
    \(label, party) -> debug (label <> " = " <> show party)
  pure p

holdingsOnly : Script Parties
holdingsOnly = do
  (p, _, _) <- setup
  -- A second instrument per dealer (GILT10 ×100) so the multi-instrument BASKET
  -- flow — a TBOND30 + GILT10 package — is quotable live in the demo desk.
  _ <- submit p.bondIssuer do
    createCmd Holding with issuer = p.bondIssuer; owner = p.dealerA; instrument = "GILT10"; amount = 100.0
  _ <- submit p.bondIssuer do
    createCmd Holding with issuer = p.bondIssuer; owner = p.dealerB; instrument = "GILT10"; amount = 100.0
  pure p

initialize : Script Parties
initialize = do
  (p, bondA, bondB) <- setup

  -- A PRIOR completed trade on a separate instrument (GILT10), fully settled via
  -- Award, so the regulator's post-trade audit trail is non-empty in the demo —
  -- showing both halves of the story at once: sealed pre-trade + auditable post-trade.
  settleCash <- submit p.cashIssuer do
    createCmd Holding with issuer = p.cashIssuer; owner = p.buyer; instrument = "USDC"; amount = 300000.0
  giltA <- submit p.bondIssuer do
    createCmd Holding with issuer = p.bondIssuer; owner = p.dealerA; instrument = "GILT10"; amount = 100.0
  giltB <- submit p.bondIssuer do
    createCmd Holding with issuer = p.bondIssuer; owner = p.dealerB; instrument = "GILT10"; amount = 100.0
  giltRfq <- submit p.buyer do
    createCmd RFQ with
      buyer = p.buyer; regulator = p.regulator
      invitedDealers = [p.dealerA, p.dealerB]
      instrument = "GILT10"; quantity = 100.0; payInstrument = "USDC"
      assetIssuer = Some p.bondIssuer; payIssuer = Some p.cashIssuer
      deadline = Some (time (date 2030 Jan 1) 0 0 0)
  gqA <- submit p.dealerA do
    exerciseCmd giltRfq SubmitQuote with dealer = p.dealerA; price = 190000.0; assetCid = giltA
  gqB <- submit p.dealerB do
    exerciseCmd giltRfq SubmitQuote with dealer = p.dealerB; price = 195000.0; assetCid = giltB
  -- Cheapest ask (dealerA) wins, paid the second price (195000) — atomic DvP, TradeReport → regulator.
  _ <- submit p.buyer do
    exerciseCmd giltRfq Award with quoteCids = [gqA, gqB]; cashCid = settleCash

  -- The LIVE RFQ for the pre-award money shot: TBOND30 + two sealed quotes, un-awarded.
  rfq <- submit p.buyer do
    createCmd RFQ with
      buyer = p.buyer; regulator = p.regulator
      invitedDealers = [p.dealerA, p.dealerB]
      instrument = "TBOND30"; quantity = 1000.0; payInstrument = "USDC"
      assetIssuer = Some p.bondIssuer; payIssuer = Some p.cashIssuer
      deadline = Some (time (date 2030 Jan 1) 0 0 0)
  _ <- submit p.dealerA do
    exerciseCmd rfq SubmitQuote with dealer = p.dealerA; price = 4210000.0; assetCid = bondA
  _ <- submit p.dealerB do
    exerciseCmd rfq SubmitQuote with dealer = p.dealerB; price = 4250000.0; assetCid = bondB
  pure p
