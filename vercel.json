{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "echo 'no build deps — read-only proxy uses only node builtins + global fetch'",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/proxy?path=$1" },
    { "source": "/", "destination": "/web/index.html" },
    { "source": "/index.html", "destination": "/web/index.html" },
    { "source": "/deck", "destination": "/slides/index.html" },
    { "source": "/deck.pdf", "destination": "/slides/tirai-deck.pdf" },
    { "source": "/app", "destination": "/web/app.html" },
    { "source": "/app.html", "destination": "/web/app.html" },
    { "source": "/app.js", "destination": "/web/app.js" },
    { "source": "/style.css", "destination": "/web/style.css" }
  ]
}
