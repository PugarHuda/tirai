-- Behavioural checks for the CIP-0056-shaped token standard: the two-step transfer
-- and the atomic DvP allocation swap. `daml test` runs these.
module Test where

import TokenStandard
import Daml.Script
import DA.Assert ((===))
import DA.Time (time)
import DA.Date (date, Month(Jan))
import DA.List (sortOn)

noMeta : Metadata
noMeta = Metadata []

-- Sum the amounts of one party's holdings of one instrument (its own view).
ownedAmount : Party -> Text -> Script Decimal
ownedAmount p inst = do
  ts <- query @Token p
  pure $ sum [t.amount | (_, t) <- ts, t.owner == p, t.instrument == inst]

-- Two-step transfer: sender proposes, receiver accepts; a partial transfer leaves
-- the remainder with the sender.
testTransferInstruction : Script ()
testTransferInstruction = script do
  issuer <- allocateParty "Issuer"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  let far = time (date 2030 Jan 1) 0 0 0

  cash <- submit issuer do
    createCmd Token with issuer; owner = alice; instrument = "USDC"; amount = 1000.0; lock = None
  ti <- submit alice do
    exerciseCmd cash TokenTransfer with receiver = bob; transferAmount = 400.0; deadline = far; meta = noMeta
  _ <- submit bob do exerciseCmd ti AcceptTransfer

  aliceHas <- ownedAmount alice "USDC"
  bobHas <- ownedAmount bob "USDC"
  aliceHas === 600.0   -- remainder stayed with the sender
  bobHas === 400.0     -- receiver got exactly the transferred amount

-- A rejected transfer returns the full amount to the sender.
testTransferReject : Script ()
testTransferReject = script do
  issuer <- allocateParty "Issuer"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  let far = time (date 2030 Jan 1) 0 0 0
  cash <- submit issuer do
    createCmd Token with issuer; owner = alice; instrument = "USDC"; amount = 500.0; lock = None
  ti <- submit alice do
    exerciseCmd cash TokenTransfer with receiver = bob; transferAmount = 500.0; deadline = far; meta = noMeta
  _ <- submit bob do exerciseCmd ti RejectTransfer
  aliceHas <- ownedAmount alice "USDC"
  bobHas <- ownedAmount bob "USDC"
  aliceHas === 500.0
  bobHas === 0.0

-- Atomic DvP: Alice pays cash, Bob delivers a bond, both legs in one transaction.
testAllocationDvp : Script ()
testAllocationDvp = script do
  issuer <- allocateParty "Issuer"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"

  cash <- submit issuer do
    createCmd Token with issuer; owner = alice; instrument = "USDC"; amount = 600.0; lock = None
  bond <- submit issuer do
    createCmd Token with issuer; owner = bob; instrument = "TBOND30"; amount = 10.0; lock = None

  legAtoB <- submit alice do
    exerciseCmd cash AllocateForSettlement with receiver = bob; settlementId = "S1"; allocAmount = 600.0; meta = noMeta
  legBtoA <- submit bob do
    exerciseCmd bond AllocateForSettlement with receiver = alice; settlementId = "S1"; allocAmount = 10.0; meta = noMeta

  dvp <- submitMulti [alice, bob] [] do
    createCmd DvpSettlement with partyA = alice; partyB = bob; settlementId = "S1"; legAtoB; legBtoA
  _ <- submit alice do exerciseCmd dvp SettleDvp

  -- After the swap: Alice holds the bond, Bob holds the cash.
  aliceBond <- ownedAmount alice "TBOND30"
  bobCash <- ownedAmount bob "USDC"
  aliceCash <- ownedAmount alice "USDC"
  bobBond <- ownedAmount bob "TBOND30"
  aliceBond === 10.0
  bobCash === 600.0
  aliceCash === 0.0
  bobBond === 0.0

-- The receiver CANNOT unilaterally pull a sender's allocation — it needs both
-- parties (i.e. a jointly-signed settlement). Guards DvP atomicity.
testAllocationNotUnilateral : Script ()
testAllocationNotUnilateral = script do
  issuer <- allocateParty "Issuer"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  cash <- submit issuer do
    createCmd Token with issuer; owner = alice; instrument = "USDC"; amount = 600.0; lock = None
  alloc <- submit alice do
    exerciseCmd cash AllocateForSettlement with receiver = bob; settlementId = "S1"; allocAmount = 600.0; meta = noMeta
  -- Bob alone must not be able to execute and take the funds.
  submitMustFail bob do exerciseCmd alloc ExecuteAllocation
  -- Alice (the allocator) can still reclaim before settlement.
  _ <- submit alice do exerciseCmd alloc CancelAllocation
  aliceHas <- ownedAmount alice "USDC"
  aliceHas === 600.0

-- A locked holding is frozen: it cannot be transferred, split or allocated, and
-- releasing it needs the owner AND the lock holder together.
testLockFreezesHolding : Script ()
testLockFreezesHolding = script do
  issuer <- allocateParty "Issuer"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  custodian <- allocateParty "Custodian"
  let far = time (date 2030 Jan 1) 0 0 0
  tok <- submit issuer do
    createCmd Token with issuer; owner = alice; instrument = "USDC"; amount = 1000.0; lock = None
  locked <- submit alice do
    exerciseCmd tok LockToken with newLock = Lock with holders = [custodian]; context = "settlement-hold"
  -- Frozen while locked: no transfer, no split, no allocation.
  submitMustFail alice do
    exerciseCmd locked TokenTransfer with receiver = bob; transferAmount = 100.0; deadline = far; meta = noMeta
  submitMustFail alice do exerciseCmd locked TokenSplit with amt = 100.0
  submitMustFail alice do
    exerciseCmd locked AllocateForSettlement with receiver = bob; settlementId = "S1"; allocAmount = 100.0; meta = noMeta
  -- The owner alone cannot release it; owner + custodian can.
  submitMustFail alice do exerciseCmd locked UnlockToken
  unlocked <- submitMulti [alice, custodian] [] do exerciseCmd locked UnlockToken
  -- Once released it is spendable again.
  _ <- submit alice do exerciseCmd unlocked TokenSplit with amt = 100.0
  total <- ownedAmount alice "USDC"
  total === 1000.0

-- A settlement cannot be pointed at legs from a different settlement id.
testDvpRejectsForeignLeg : Script ()
testDvpRejectsForeignLeg = script do
  issuer <- allocateParty "Issuer"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  cash <- submit issuer do
    createCmd Token with issuer; owner = alice; instrument = "USDC"; amount = 600.0; lock = None
  bond <- submit issuer do
    createCmd Token with issuer; owner = bob; instrument = "TBOND30"; amount = 10.0; lock = None
  legAtoB <- submit alice do
    exerciseCmd cash AllocateForSettlement with receiver = bob; settlementId = "S1"; allocAmount = 600.0; meta = noMeta
  -- Bob's leg belongs to a DIFFERENT settlement.
  legBtoA <- submit bob do
    exerciseCmd bond AllocateForSettlement with receiver = alice; settlementId = "S-OTHER"; allocAmount = 10.0; meta = noMeta
  dvp <- submitMulti [alice, bob] [] do
    createCmd DvpSettlement with partyA = alice; partyB = bob; settlementId = "S1"; legAtoB; legBtoA
  submitMustFail alice do exerciseCmd dvp SettleDvp
  -- Nothing moved: both allocations are still reserved.
  aliceBond <- ownedAmount alice "TBOND30"
  bobCash <- ownedAmount bob "USDC"
  aliceBond === 0.0
  bobCash === 0.0

-- A transfer cannot be accepted once its deadline has passed; the sender can still
-- reclaim it, so funds are never stranded.
testTransferExpiry : Script ()
testTransferExpiry = script do
  issuer <- allocateParty "Issuer"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  let deadline = time (date 2030 Jan 1) 0 0 0
  cash <- submit issuer do
    createCmd Token with issuer; owner = alice; instrument = "USDC"; amount = 500.0; lock = None
  ti <- submit alice do
    exerciseCmd cash TokenTransfer with receiver = bob; transferAmount = 500.0; deadline; meta = noMeta
  -- Move the ledger clock past the deadline: the receiver can no longer accept.
  setTime (time (date 2030 Jan 2) 0 0 0)
  submitMustFail bob do exerciseCmd ti AcceptTransfer
  -- Not stranded: the sender withdraws and gets the full amount back.
  _ <- submit alice do exerciseCmd ti WithdrawTransfer
  aliceHas <- ownedAmount alice "USDC"
  bobHas <- ownedAmount bob "USDC"
  aliceHas === 500.0
  bobHas === 0.0

-- Amount and instrument boundaries are enforced.
testAmountBoundaries : Script ()
testAmountBoundaries = script do
  issuer <- allocateParty "Issuer"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  let far = time (date 2030 Jan 1) 0 0 0
  usdc <- submit issuer do
    createCmd Token with issuer; owner = alice; instrument = "USDC"; amount = 100.0; lock = None
  eur <- submit issuer do
    createCmd Token with issuer; owner = alice; instrument = "EUR"; amount = 50.0; lock = None
  -- Split must be strictly inside (0, amount).
  submitMustFail alice do exerciseCmd usdc TokenSplit with amt = 0.0
  submitMustFail alice do exerciseCmd usdc TokenSplit with amt = 100.0
  submitMustFail alice do exerciseCmd usdc TokenSplit with amt = 150.0
  -- Cannot transfer or allocate more than is held.
  submitMustFail alice do
    exerciseCmd usdc TokenTransfer with receiver = bob; transferAmount = 100.1; deadline = far; meta = noMeta
  submitMustFail alice do
    exerciseCmd usdc AllocateForSettlement with receiver = bob; settlementId = "S1"; allocAmount = 100.1; meta = noMeta
  -- Cannot merge holdings of different instruments.
  submitMustFail alice do exerciseCmd usdc TokenMerge with otherCid = eur
  -- Nothing above moved anything.
  stillUsdc <- ownedAmount alice "USDC"
  stillEur <- ownedAmount alice "EUR"
  stillUsdc === 100.0
  stillEur === 50.0

-- Split then merge round-trips the amount.
testSplitMerge : Script ()
testSplitMerge = script do
  issuer <- allocateParty "Issuer"
  alice <- allocateParty "Alice"
  tok <- submit issuer do
    createCmd Token with issuer; owner = alice; instrument = "USDC"; amount = 1000.0; lock = None
  (a, b) <- submit alice do exerciseCmd tok TokenSplit with amt = 300.0
  _ <- submit alice do exerciseCmd a TokenMerge with otherCid = b
  total <- ownedAmount alice "USDC"
  total === 1000.0
  -- and it is a single consolidated holding
  ts <- query @Token alice
  length (sortOn (\(_, t) -> t.amount) ts) === 1
